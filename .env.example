# ── Database ────────────────────────────────────────────────────────────────
# Your Neon PostgreSQL connection string.
# Get one for free at https://neon.com — create a project and copy the
# "Connection string" from the dashboard.
DATABASE_URL="postgresql://user:password@ep-your-host.neon.tech/dbname?sslmode=require"

# ── Auth ────────────────────────────────────────────────────────────────────
# Secret used to sign session JWT cookies. Any long random string (32+
# characters recommended). Keep this private. Changing it invalidates
# all existing user sessions.
#
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-string-at-least-32-characters"
