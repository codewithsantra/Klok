// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  PENDING
  DONE
  SKIPPED
}

enum Recurrence {
  NONE
  DAILY
  WEEKDAYS
  WEEKLY
  CUSTOM
}

model User {
  id        String     @id @default(cuid())
  // Clerk owns identity; this row holds app data and relations.
  clerkId   String?    @unique
  email     String     @unique
  name      String?
  timeZone  String     @default("UTC")
  tags      Tag[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  templates Template[]
  dailyGoals DailyGoal[]
  tasks         Task[]
  timerSessions TimerSession[]
}

model Tag {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  emoji          String
  active         Boolean         @default(true)
  dailyGoals     DailyGoal[]
  createdAt      DateTime        @default(now())
  templateTasks  TemplateTask[]
  tasks          Task[]
  timerSessions  TimerSession[]
}

model DailyGoal {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tagId         String
  tag           Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  date          DateTime @db.Date
  targetMinutes Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, tagId, date])
}

// ── Tasks ────────────────────────────────────────────────────

model Task {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  tagId           String?
  tag             Tag?         @relation(fields: [tagId], references: [id], onDelete: SetNull)
  date            DateTime     @db.Date
  startTime       String
  endTime         String
  status          TaskStatus   @default(PENDING)
  note            String?
  recurrence      Recurrence   @default(NONE)
  daysOfWeek      Int[]        @default([])
  repeatEvery     Int          @default(1)
  repeatUnit      String?      // "day" | "week" | "month" | "year"
  repeatEndDate   DateTime?    @db.Date
  repeatEndCount  Int?
  // Self-referential: an instance points to its recurring "template" Task.
  recurringRuleId String?
  carriedFromId   String?
  timerSubItems   TimerSubItem[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId, date])
}

// ── Focus Timer ──────────────────────────────────────────────

model TimerSession {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  tagId         String?
  tag           Tag?           @relation(fields: [tagId], references: [id], onDelete: SetNull)
  date          DateTime       @db.Date
  targetMinutes Int
  subItems      TimerSubItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId, date])
}

model TimerSubItem {
  id             String        @id @default(cuid())
  sessionId      String
  session        TimerSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title          String
  targetMinutes  Int
  timerStartedAt DateTime?
  timerAccumMs   Int           @default(0)
  taskId         String?
  task           Task?         @relation(fields: [taskId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// ── Day Templates ────────────────────────────────────────────
// A named set of task "shapes" that can be applied to any date,
// creating real Tasks for that day.

model Template {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  icon      String?
  iconColor String?
  items     TemplateTask[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model TemplateTask {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tagId      String?
  tag        Tag?     @relation(fields: [tagId], references: [id], onDelete: SetNull)
  title      String
  startTime  String
  endTime    String
  createdAt  DateTime @default(now())
}
