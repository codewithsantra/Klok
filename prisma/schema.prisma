// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BlockStatus {
  PLANNED
  DONE
  PARTIAL
  SKIPPED
}

enum TodoStatus {
  PENDING
  DONE
  INCOMPLETE
  SKIPPED
}

enum MetricType {
  TIME
  DISTANCE
  COUNT
  CUSTOM
}

// ── New flow ──

enum TaskStatus {
  PENDING
  DONE
  SKIPPED
}

enum Recurrence {
  NONE
  DAILY
  WEEKDAYS
  WEEKLY
  CUSTOM
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  password  String
  timeZone  String     @default("UTC")
  emailVerifiedAt DateTime?
  tags      Tag[]
  blocks    Block[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  templates Template[]
  recurringRules RecurringRule[]
  dailyGoals DailyGoal[]
  passwordResetTokens PasswordResetToken[]
  verificationTokens  VerificationToken[]
  tasks         Task[]
  timerSessions TimerSession[]
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Tag {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  emoji          String
  active         Boolean         @default(true)
  blocks         Block[]
  dailyGoals     DailyGoal[]
  createdAt      DateTime        @default(now())
  templateBlocks TemplateBlock[]
  tasks          Task[]
  timerSessions  TimerSession[]
}

model DailyGoal {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tagId         String
  tag           Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  date          DateTime @db.Date
  targetMinutes Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, tagId, date])
}

model Block {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tagId             String?
  tag               Tag?        @relation(fields: [tagId], references: [id], onDelete: SetNull)
  date              DateTime    @db.Date
  startTime         String
  endTime           String
  title             String
  status            BlockStatus @default(PLANNED)
  recurrence        Recurrence  @default(NONE)
  recurrenceEndDate DateTime?   @db.Date
  recurringRuleId   String?
  recurringRule     RecurringRule? @relation(fields: [recurringRuleId], references: [id], onDelete: SetNull)
  todos             Todo[]
  // Block-level tracking (used when a block has no todos but you still
  // want to time it or track a target — e.g. "Study" for 2h).
  metricType        MetricType?
  metricUnit        String?
  metricTarget      Float?
  metricActual      Float       @default(0)
  timerStartedAt    DateTime?
  timerAccumMs      Int         @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Todo {
  id               String     @id @default(cuid())
  blockId          String
  block            Block      @relation(fields: [blockId], references: [id], onDelete: Cascade)
  text             String
  status           TodoStatus @default(PENDING)
  comment          String?
  completedLaterAt String?

  // ── Trackable goal (NULL on simple todos) ──
  metricType   MetricType?
  metricUnit   String?
  metricTarget Float?
  metricActual Float       @default(0)

  // ── Timer (only meaningful when metricType == TIME) ──
  timerStartedAt DateTime?
  timerAccumMs   Int        @default(0)

  // ── Carry-forward lineage ──
  carriedFromId String?

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Template {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  icon      String?
  iconColor String?
  blocks    TemplateBlock[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model TemplateBlock {
  id         String         @id @default(cuid())
  templateId String
  template   Template       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tagId      String?
  tag        Tag?           @relation(fields: [tagId], references: [id], onDelete: SetNull)
  startTime  String
  endTime    String
  title      String
  todos      TemplateTodo[]
  createdAt  DateTime       @default(now())
}

model TemplateTodo {
  id              String        @id @default(cuid())
  templateBlockId String
  templateBlock   TemplateBlock @relation(fields: [templateBlockId], references: [id], onDelete: Cascade)
  text            String
  createdAt       DateTime      @default(now())
}

// ── New flow models ─────────────────────────────────────────

model Task {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  tagId           String?
  tag             Tag?         @relation(fields: [tagId], references: [id], onDelete: SetNull)
  date            DateTime     @db.Date
  startTime       String
  endTime         String
  status          TaskStatus   @default(PENDING)
  note            String?
  recurrence      Recurrence   @default(NONE)
  daysOfWeek      Int[]        @default([])
  repeatEvery     Int          @default(1)
  repeatUnit      String?      // "day" | "week" | "month" | "year"
  repeatEndDate   DateTime?    @db.Date
  repeatEndCount  Int?
  recurringRuleId String?
  carriedFromId   String?
  timerSubItems   TimerSubItem[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId, date])
}

model TimerSession {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  tagId         String?
  tag           Tag?           @relation(fields: [tagId], references: [id], onDelete: SetNull)
  date          DateTime       @db.Date
  targetMinutes Int
  subItems      TimerSubItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId, date])
}

model TimerSubItem {
  id             String        @id @default(cuid())
  sessionId      String
  session        TimerSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title          String
  targetMinutes  Int
  timerStartedAt DateTime?
  timerAccumMs   Int           @default(0)
  taskId         String?
  task           Task?         @relation(fields: [taskId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// A recurring block template that materializes into real Blocks on /today load.
model RecurringRule {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  emoji        String     @default("🔁")
  tagId        String?
  startTime    String
  endTime      String
  recurrence   Recurrence @default(DAILY)
  daysOfWeek   Int[]      @default([])
  startDate    DateTime   @db.Date
  endDate      DateTime?  @db.Date
  active       Boolean    @default(true)
  todosTemplate Json      @default("[]")
  lastRunDate  DateTime?  @db.Date
  blocks       Block[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}
